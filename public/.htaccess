# SPA fallback for React Router on Hostinger (Apache)
# Any URL that isn't a real file/folder is rewritten to index.html
# so client-side routes like /gatewayhub and /gatewayhub/admin work
# on direct load and refresh.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite the API folder — let PHP handle it
  RewriteRule ^api/ - [L]

  # Don't rewrite real files or directories (assets, brochures, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else -> index.html (SPA)
  RewriteRule . /index.html [L]
</IfModule>

# Sensible caching for hashed Vite assets
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?|ttf|otf|eot|svg|png|jpe?g|webp|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Force HTTPS
<IfModule mod_rewrite.c>
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>
